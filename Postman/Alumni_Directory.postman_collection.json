{
	"info": {
		"name": "Final Alumni Directory API Collection",
		"description": "Complete API Collection containing Authentication, Directory, System Admin, Uni Admin, Student Views, and Profile features.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Authentication",
			"item": [
				{
					"name": "1.1 Register as Alumni",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Md. Mahfuz\",\n    \"email\": \"mahfuz.alumni@example.com\",\n    \"password\": \"pass1234\",\n    \"role\": \"alumni\",\n    \"university_id\": \"PASTE_UNIVERSITY_ID_HERE\",\n    \"department\": \"CSE\",\n    \"graduation_year\": 2023,\n    \"student_roll_no\": \"UG02-43-18-051\",\n    \"company\": \"Google\",\n    \"position\": \"Software Engineer\",\n    \"contact_number\": \"01712345678\",\n    \"linkedin_id\": \"https://linkedin.com/in/mahfuz\",\n    \"github_id\": \"https://github.com/mahfuz\"\n}"
						},
						"url": "{{base_url}}/api/auth/register"
					}
				},
				{
					"name": "1.2 Register as Student",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Sabbir Hossain\",\n    \"email\": \"sabbir.student@example.com\",\n    \"password\": \"pass1234\",\n    \"role\": \"student\",\n    \"university_id\": \"PASTE_UNIVERSITY_ID_HERE\",\n    \"department\": \"BBA\",\n    \"graduation_year\": 2026,\n    \"contact_number\": \"01812345678\"\n}"
						},
						"url": "{{base_url}}/api/auth/register"
					}
				},
				{
					"name": "1.3 Login (All Users & Admins)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"mahfuz.alumni@example.com\",\n    \"password\": \"pass1234\",\n    \"role\": \"alumni\"\n}"
						},
						"url": "{{base_url}}/api/auth/login"
					}
				}
			]
		},
		{
			"name": "2. Universities",
			"item": [
				{
					"name": "2.1 Get All Universities (Public)",
					"request": {
						"method": "GET",
						"header": [],
						"url": "{{base_url}}/api/universities"
					}
				},
				{
					"name": "2.2 Add University (System Admin)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Daffodil International University\",\n    \"location\": \"Ashulia, Savar, Dhaka\"\n}"
						},
						"url": "{{base_url}}/api/universities"
					}
				},
				{
					"name": "2.3 Edit University (System Admin)",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Daffodil International University (Updated)\",\n    \"location\": \"Smart City, Ashulia, Dhaka\"\n}"
						},
						"url": "{{base_url}}/api/universities/UNI_ID_HERE"
					}
				},
				{
					"name": "2.4 Delete University (System Admin)",
					"request": {
						"method": "DELETE",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": "{{base_url}}/api/universities/UNI_ID_HERE"
					}
				}
			]
		},
		{
			"name": "3. Directory & Views",
			"item": [
				{
					"name": "3.1 Smart Directory Search (Role Based)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": {
							"raw": "{{base_url}}/api/directory?department=CSE",
							"host": ["{{base_url}}"],
							"path": ["api", "directory"],
							"query": [
								{ "key": "department", "value": "CSE" },
								{ "key": "company", "value": "Google", "disabled": true },
								{ "key": "graduation_year", "value": "2023", "disabled": true }
							]
						}
					}
				},
				{
					"name": "3.2 View Own Uni Alumni (Student/Alumni View)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": "{{base_url}}/api/my-university/alumni",
						"description": "Student/Alumni shudhu nijer uni-r Verified alumni dekhbe."
					}
				}
			]
		},
		{
			"name": "4. System Admin Actions",
			"item": [
				{
					"name": "4.1 Create Uni Admin",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"DIU Controller\",\n    \"email\": \"admin@diu.edu.bd\",\n    \"password\": \"admin123\",\n    \"university_id\": \"PASTE_UNIVERSITY_ID_HERE\"\n}"
						},
						"url": "{{base_url}}/api/admin/system/create-uni-admin"
					}
				},
				{
					"name": "4.2 Edit Uni Admin Details",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"DIU Super Admin\"\n}"
						},
						"url": "{{base_url}}/api/admin/system/uni-admin/UNI_ADMIN_ID_HERE"
					}
				},
				{
					"name": "4.3 Get ALL Alumni (Cross-University)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": "{{base_url}}/api/admin/system/all-alumni"
					}
				},
				{
					"name": "4.4 Delete ANY Alumni",
					"request": {
						"method": "DELETE",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": "{{base_url}}/api/admin/system/alumni/ALUMNI_ID_HERE"
					}
				}
			]
		},
		{
			"name": "5. University Admin Actions",
			"item": [
				{
					"name": "5.1 View ALL Own Uni Alumni (For Verification)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": "{{base_url}}/api/admin/uni/all-alumni",
						"description": "Uni Admin nijer uni-r shob (Verified + Unverified) alumni dekhbe."
					}
				},
				{
					"name": "5.2 Verify Alumni",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": "{{base_url}}/api/admin/uni/verify/ALUMNI_ID_HERE"
					}
				},
				{
					"name": "5.3 Unverify (Reject) Alumni",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": "{{base_url}}/api/admin/uni/unverify/ALUMNI_ID_HERE"
					}
				},
				{
					"name": "5.4 Delete Own Uni Alumni",
					"request": {
						"method": "DELETE",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": "{{base_url}}/api/admin/uni/alumni/ALUMNI_ID_HERE"
					}
				},
				{
					"name": "5.5 Delete Own Uni Student",
					"request": {
						"method": "DELETE",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": "{{base_url}}/api/admin/uni/student/STUDENT_ID_HERE"
					}
				}
			]
		},
		{
			"name": "6. Profile Management",
			"item": [
				{
					"name": "6.1 Get User Profile",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": "{{base_url}}/api/alumni/profile/USER_ID_HERE"
					}
				},
				{
					"name": "6.2 Update User Profile",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"company\": \"Microsoft\",\n    \"position\": \"Senior Software Engineer\",\n    \"contact_number\": \"01999999999\",\n    \"linkedin_id\": \"https://linkedin.com/in/mahfuz-updated\"\n}"
						},
						"url": "{{base_url}}/api/alumni/profile/USER_ID_HERE"
					}
				}
			]
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:5000",
			"type": "string"
		},
		{
			"key": "token",
			"value": "PASTE_YOUR_JWT_TOKEN_HERE_AFTER_LOGIN",
			"type": "string"
		}
	]
}